# Copy to `.env` and fill in. The Taskfile loads `.env` automatically (dotenv); `.env` is gitignored.
# Values already exported in your shell take precedence over these.
#
# Format: KEY=value (no `export`, no spaces around `=`). Quote values containing spaces.

# --- Core AWS ---
AWS_REGION=us-east-1

# Your 12-digit AWS account id. Used only to build globally-unique S3 bucket names
# (<account>-ai-gallery-uploads-<region> / <account>-ai-gallery-assets-<region>).
# Find it with: aws sts get-caller-identity --query Account --output text
AWS_ACCOUNT_ID=REPLACE_WITH_ACCOUNT_ID

# --- Terraform state ---
# Globally-unique S3 bucket that stores this lab's Terraform state.
TF_STATE_BUCKET=REPLACE_WITH_STATE_BUCKET

# --- DNS ---
# An EXISTING public Route 53 hosted zone you own. This lab creates a NEW child hosted zone for
# APP_DOMAIN and delegates it from PARENT_ZONE_NAME (NS records written into the parent).
PARENT_ZONE_NAME=example.com

# Public hostname the gallery is served on over HTTPS. It is also the name of the delegated child
# zone this lab creates, so it must be a subdomain of PARENT_ZONE_NAME.
APP_DOMAIN=ai-gallery.example.com

# --- CI / GitHub OIDC ---
# OWNER/REPO allowed to assume the CI deploy role via GitHub Actions OIDC.
GITHUB_REPOSITORY=gichie534/labs

# --- Bedrock ---
# Model used to generate image descriptions. Newer Claude models require a cross-region inference
# profile (the `us.` prefix), not the bare foundation-model id. Enable access to the underlying model
# in the Bedrock console first.
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0

# --- Pillow layer for the push Lambda ---
# Public Klayers Pillow layer for python3.12 (x86_64). Region-specific — update if AWS_REGION changes.
# Klayers republishes layers and bumps the version number, so this ARN goes stale over time. Look up
# the current one: curl -s https://api.klayers.cloud/api/v2/p3.12/layers/latest/us-east-1/Pillow
# (see https://github.com/keithrozario/Klayers), and swap the region if AWS_REGION changes.
PILLOW_LAYER_ARN=arn:aws:lambda:us-east-1:770693421928:layer:Klayers-p312-Pillow:11
