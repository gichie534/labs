# Copy to .env and fill in. `.env` is gitignored.

# Region everything is created in.
AWS_REGION=us-east-1

# Globally-unique S3 bucket that stores this lab's Terraform state.
TF_STATE_BUCKET=REPLACE_WITH_STATE_BUCKET

# Globally-unique name for the DEMO bucket the policy matrix is evaluated against (not the state
# bucket). Must be globally unique.
DEMO_BUCKET=REPLACE_WITH_GLOBALLY_UNIQUE_DEMO_BUCKET
