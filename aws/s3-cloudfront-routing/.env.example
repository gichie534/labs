# Copy to .env and fill in. `.env` is gitignored.

# Region the buckets are created in (CloudFront is global).
AWS_REGION=us-east-1

# Globally-unique S3 bucket that stores this lab's Terraform state.
TF_STATE_BUCKET=REPLACE_WITH_STATE_BUCKET

# Globally-unique base name for the three content buckets. The lab creates
# "<BUCKET_PREFIX>-site", "<BUCKET_PREFIX>-jpg", and "<BUCKET_PREFIX>-pdf".
# Must be globally unique across all of S3.
BUCKET_PREFIX=REPLACE_WITH_GLOBALLY_UNIQUE_PREFIX
