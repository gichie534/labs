# Copy to .env and fill in. `.env` is gitignored.

# Region everything is created in.
AWS_REGION=us-east-1

# Globally-unique S3 bucket that stores this lab's Terraform state.
TF_STATE_BUCKET=REPLACE_WITH_STATE_BUCKET

# Globally-unique name for the DEMO bucket the ABAC policy protects (not the state bucket).
# Leave as-is to let it default to "ec2-abac-s3-lab-<your-suffix>"; must be globally unique.
ABAC_BUCKET=REPLACE_WITH_GLOBALLY_UNIQUE_DEMO_BUCKET
