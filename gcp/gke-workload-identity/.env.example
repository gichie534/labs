# Copy to `.env` and fill in. The Taskfile loads `.env` automatically (dotenv); `.env` is gitignored.
# Values already exported in your shell take precedence over these.
#
# Format: KEY=value (no `export`, no spaces around `=`).

# --- Core GCP ---
GCP_PROJECT=my-project
GCP_REGION=us-central1
# Project NUMBER (not ID). Used both for the GKE node SA that pulls images and for the federated
# KSA principal in the workload-identity unit.
# gcloud projects describe "$GCP_PROJECT" --format='value(projectNumber)'
GCP_PROJECT_NUMBER=123456789012

# --- Terraform state ---
TF_STATE_BUCKET=my-tf-state-bucket

# --- CI / GitHub Workload Identity Federation (pipeline auth; separate from the lab's subject) ---
# OWNER/REPO allowed to federate into the GitHub WIF pool.
GITHUB_REPOSITORY=owner/repo

# The two demo data buckets are derived automatically from GCP_PROJECT as:
#   <project>-wif-allowed  and  <project>-wif-denied
# so there's nothing to set here.
