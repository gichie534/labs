# Copy to `.env` and fill in. The Taskfile loads `.env` automatically (dotenv); `.env` is gitignored.
# Values already exported in your shell take precedence over these.
#
# Format: KEY=value (no `export`, no spaces around `=`). Quote values containing spaces.

# --- Core GCP ---
GCP_PROJECT=my-project
GCP_REGION=us-central1
# Project NUMBER (not ID) — used to build the GKE node SA that pulls images.
# gcloud projects describe "$GCP_PROJECT" --format='value(projectNumber)'
GCP_PROJECT_NUMBER=123456789012

# --- Terraform state ---
TF_STATE_BUCKET=my-tf-state-bucket

# --- CI / Workload Identity Federation ---
# OWNER/REPO allowed to federate into the WIF pool.
GITHUB_REPOSITORY=owner/repo

# --- Public HTTPS endpoint ---
# Apex hostname the app is served on (the child zone the lab creates + delegates).
INGRESS_DOMAIN=gke-ingress.gcp.example.com

# --- Parent DNS zone (delegation target) ---
# Cloud DNS managed-zone RESOURCE NAME (not the domain) of the existing parent zone.
# gcloud dns managed-zones list --project "$PARENT_DNS_PROJECT" --format='table(name,dnsName)'
PARENT_DNS_ZONE=gcp-example-com
# Project that owns the parent zone (a separate bootstrap project). Omit if same as GCP_PROJECT.
PARENT_DNS_PROJECT=my-bootstrap-project

# --- Set automatically by `task gke-ingress:dns` (phase 2); leave unset normally ---
# INGRESS_IP=
