# Copy to `.env` and fill in. The Taskfile loads `.env` automatically (dotenv); `.env` is gitignored.
# Values already exported in your shell take precedence over these.
#
# Format: KEY=value (no `export`, no spaces around `=`).

# --- Core GCP ---
GCP_PROJECT=my-project
GCP_REGION=us-central1
# Project NUMBER (not ID). Forms the federated KSA principal in IAM bindings.
# gcloud projects describe "$GCP_PROJECT" --format='value(projectNumber)'
GCP_PROJECT_NUMBER=123456789012

# --- Terraform state ---
TF_STATE_BUCKET=my-tf-state-bucket
