# Copy to `.env` and fill in. The Taskfile loads `.env` automatically (dotenv); `.env` is gitignored.
# Values already exported in your shell take precedence over these.
#
# Format: KEY=value (no `export`, no spaces around `=`).

# --- Core GCP ---
GCP_PROJECT=my-project
GCP_REGION=us-central1
# Project NUMBER (not ID). Used for the GKE node SA that pulls images from Artifact Registry.
# gcloud projects describe "$GCP_PROJECT" --format='value(projectNumber)'
GCP_PROJECT_NUMBER=123456789012

# --- Core AWS ---
# Region for the SQS queue and the IAM roles/provider. Your AWS credentials (for `terragrunt apply`)
# come from your normal AWS CLI environment (profile / SSO / env vars) — only the region is set here.
AWS_REGION=us-east-1

# --- Terraform state ---
TF_STATE_BUCKET=my-tf-state-bucket

# The Kubernetes namespace and the writer/reader service-account names are fixed in root.hcl
# (sqsdemo / writer / reader) and must match the Helm chart, so there's nothing to set here.
