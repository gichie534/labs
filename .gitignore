# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# Dependency directories (remove the comment below to include it)
# vendor/

# Terraform / Terragrunt
# Local .terraform directories
**/.terraform/*

# Terragrunt cache directories
.terragrunt-cache/
**/.terragrunt-cache/

# Terraform state files (should be stored remotely)
*.tfstate
*.tfstate.*

# Crash log files
crash.log
crash.*.log

# Terraform variable files that may contain secrets
*.tfvars
*.tfvars.json

# Terraform plan output files
*.tfplan
*.tfplan.*

# Override files (typically used for local overrides)
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# CLI configuration and credential files
.terraformrc
terraform.rc

# Go workspace file
go.work
go.work.sum

# env file
.env

# Lambda build artifacts (compiled bootstrap + deployment zip)
**/app/go/build/
function.zip
bootstrap

# MacOS
.DS_Store

# Editor/IDE
# .idea/
# .vscode/
